rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: admin, teacher, student)
    //   - photoURL: string (optional, uri format)
    //   - createdAt: timestamp (required)
    //
    // Collection: courses
    // Document ID: courseId
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - semester: int (required)
    //   - teacherId: string (optional) - UID of assigned teacher
    //
    // Collection: subjects
    // Document ID: subjectId
    // Fields:
    //   - name: string (required)
    //   - courseId: string (required)
    //   - semester: int (required)
    //
    // Collection: attendance
    // Document ID: attendanceId
    // Fields:
    //   - studentId: string (required)
    //   - courseId: string (required)
    //   - subjectId: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - status: string (required, enum: present, absent, late)
    //
    // Collection: fees
    // Document ID: feeId
    // Fields:
    //   - studentId: string (required)
    //   - amount: number (required)
    //   - dueDate: string (required, YYYY-MM-DD)
    //   - status: string (required, enum: paid, pending)
    //   - paymentDate: timestamp (optional)
    //
    // Collection: assignments
    // Document ID: assignmentId
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - courseId: string (required)
    //   - subjectId: string (optional)
    //   - dueDate: timestamp (required)
    //   - type: string (required, enum: assignment, quiz)
    //
    // Collection: submissions
    // Document ID: submissionId
    // Fields:
    //   - assignmentId: string (required)
    //   - studentId: string (required)
    //   - fileUrl: string (required, uri)
    //   - submittedAt: timestamp (required)
    //   - grade: string (optional)
    //
    // Collection: resources
    // Document ID: resourceId
    // Fields:
    //   - title: string (required)
    //   - type: string (required, enum: pdf, ppt, video, book)
    //   - fileUrl: string (required, uri)
    //   - courseId: string (required)
    //   - subjectId: string (optional)
    //
    // Collection: notifications
    // Document ID: notificationId
    // Fields:
    //   - recipientId: string (required) - UID or 'all'
    //   - title: string (required)
    //   - message: string (required)
    //   - createdAt: timestamp (required)
    //   - read: bool (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Hardened Admin Check: Check email first to avoid get() overhead and potential failures
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "nawazidrees4323@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isTeacher() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isApproved() {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved')
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && data.name is string && 
             data.email is string && data.role is string && 
             data.status is string && data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow get: if isAuthenticated();
      allow list: if isAdmin(); // Only admins can list all users
      allow create: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow get, list: if isApproved();
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    match /fees/{feeId} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.studentId);
      allow list: if isAdmin() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /quizzes/{quizId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /quiz_attempts/{attemptId} {
      allow read: if isApproved() && (request.auth.uid == resource.data.studentId || isAdmin() || isTeacher());
      allow create: if isApproved() && request.auth.uid == request.resource.data.studentId;
      allow update: if isApproved() && (request.auth.uid == resource.data.studentId || isAdmin() || isTeacher());
      allow delete: if isAdmin();
    }

    match /question_bank/{questionId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /quiz_results/{resultId} {
      allow get: if isApproved() && (request.auth.uid == resource.data.studentId || isAdmin() || isTeacher());
      allow list: if isApproved() && (resource.data.studentId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if isApproved() && request.auth.uid == request.resource.data.studentId;
      allow update, delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow get: if isAdmin() || isTeacher() || (isAuthenticated() && request.auth.uid == resource.data.studentId);
      allow list: if isAdmin() || isTeacher() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent() && isApproved() && request.auth.uid == request.resource.data.studentId;
      allow update: if isAdmin() || isTeacher() || (isAuthenticated() && request.auth.uid == resource.data.studentId);
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all' || isAdmin());
      allow list: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all' || isAdmin());
      allow create: if isAdmin() || isTeacher();
      allow update: if isAuthenticated() && (resource.data.recipientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /quiz_schedule/{scheduleId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /vouchers/{voucherId} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.studentId);
      allow list: if isAdmin() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow get, list: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
