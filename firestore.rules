rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: admin, teacher, student)
    //   - photoURL: string (optional, uri format)
    //   - createdAt: timestamp (required)
    //
    // Collection: courses
    // Document ID: courseId
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - semester: int (required)
    //   - teacherId: string (optional) - UID of assigned teacher
    //
    // Collection: subjects
    // Document ID: subjectId
    // Fields:
    //   - name: string (required)
    //   - courseId: string (required)
    //   - semester: int (required)
    //
    // Collection: attendance
    // Document ID: attendanceId
    // Fields:
    //   - studentId: string (required)
    //   - courseId: string (required)
    //   - subjectId: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - status: string (required, enum: present, absent, late)
    //
    // Collection: fees
    // Document ID: feeId
    // Fields:
    //   - studentId: string (required)
    //   - amount: number (required)
    //   - dueDate: string (required, YYYY-MM-DD)
    //   - status: string (required, enum: paid, pending)
    //   - paymentDate: timestamp (optional)
    //
    // Collection: assignments
    // Document ID: assignmentId
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - courseId: string (required)
    //   - subjectId: string (optional)
    //   - dueDate: timestamp (required)
    //   - type: string (required, enum: assignment, quiz)
    //
    // Collection: submissions
    // Document ID: submissionId
    // Fields:
    //   - assignmentId: string (required)
    //   - studentId: string (required)
    //   - fileUrl: string (required, uri)
    //   - submittedAt: timestamp (required)
    //   - grade: string (optional)
    //
    // Collection: resources
    // Document ID: resourceId
    // Fields:
    //   - title: string (required)
    //   - type: string (required, enum: pdf, ppt, video, book)
    //   - fileUrl: string (required, uri)
    //   - courseId: string (required)
    //   - subjectId: string (optional)
    //
    // Collection: notifications
    // Document ID: notificationId
    // Fields:
    //   - recipientId: string (required) - UID or 'all'
    //   - title: string (required)
    //   - message: string (required)
    //   - createdAt: timestamp (required)
    //   - read: bool (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // SUPER ADMIN BYPASS: This email always has full access
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "nawazidrees4323@gmail.com";
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isTeacher() {
      return isAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    function isApproved() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == uid) || isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /fees/{feeId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.studentId == request.auth.uid));
      allow write: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /submissions/{submissionId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.auth.uid == request.resource.data.studentId;
      allow update: if isApproved() && (isAdmin() || isTeacher() || request.auth.uid == resource.data.studentId);
      allow delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if isApproved() && (isAdmin() || isTeacher() || resource.data.startTime == null || resource.data.startTime <= request.time);
      allow write: if isAdmin() || isTeacher();
    }

    match /quiz_attempts/{attemptId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.auth.uid == request.resource.data.studentId;
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    match /quiz_results/{resultId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /quiz_schedule/{scheduleId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /question_bank/{questionId} {
      allow read: if isApproved();
      allow write: if isAdmin() || isTeacher();
    }

    match /vouchers/{voucherId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.studentId == request.auth.uid));
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
